# BytePlus ModelArk / Seedance (international). Also accepts ARK_API_KEY.
BYTEPLUS_API_KEY=
# ap-southeast-1 (default). For eu-west-1 use: https://ark.eu-west.bytepluses.com/api/v3
# See https://docs.byteplus.com/en/docs/ModelArk/1330310
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=dreamina-seedance-2-0-260128

# Force sample clips and instant demo flow (ignores real API).
DEMO_MODE=false

# If a Seedance call fails, fill that variant with a mock clip so the demo still completes.
FALLBACK_MOCK_ON_ERROR=true

# Polling for task completion
POLL_INTERVAL_SEC=2
POLL_MAX_ATTEMPTS=120

# CORS: comma-separated origins (add your Render static site URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Recommendation text uses the same ModelArk API key as video (Chat Completions API).
# Use a text model ID from the model list — not a Seedance video model.
# https://docs.byteplus.com/en/docs/ModelArk/1330310
LLM_PROVIDER=byteplus
LLM_MODEL=seed-2-0-lite-260228

# Optional: OpenAI (or other OpenAI-compatible) instead
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
